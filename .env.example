# API Keys and Credentials
# Copy this file to .env and fill in your actual values

# Gmail API (if needed beyond MCP)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Google Sheets API
GOOGLE_SHEETS_CREDENTIALS_PATH=credentials.json

# Modal (for webhooks)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Slack (for webhook notifications)
SLACK_WEBHOOK_URL=

# Other API keys as needed
# Add your API keys here following the format:
# SERVICE_NAME_API_KEY=your_key_here
